{
  "name": "@jayf0x/fluidity-js",
  "version": "0.1.3",
  "description": "High-performance WebGL fluid simulation for React — text and image effects",
  "type": "module",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:demo": "bash scripts/deploy-demo.sh",
    "publish:npm": "bash ./scripts/publish-npm.sh"
  },
  "keywords": [
    "webgl",
    "fluid",
    "simulation",
    "react",
    "animation",
    "canvas"
  ],
  "author": "https://github.com/jayf0x",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayf0x/fluidity.git"
  },
  "bugs": {
    "url": "https://github.com/jayf0x/fluidity/issues"
  },
  "homepage": "https://github.com/jayf0x/fluidity#readme",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitejs/plugin-react": "^4.2.0",
    "jsdom": "^23.2.0",
    "prettier": "^3.8.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^4.5.0",
    "vitest": "^0.34.0"
  }
}
